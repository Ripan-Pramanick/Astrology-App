# Server Environment Variables
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5174

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Astrology API (https://astrologyapi.com)
# Get these from your AstrologyAPI dashboard
# Auth = Basic base64(ASTROLOGY_USER_ID:ASTROLOGY_WALLET_TOKEN)
ASTROLOGY_USER_ID=638879       # Your numeric user ID
ASTROLOGY_WALLET_TOKEN=your_wallet_token_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
